<!DOCTYPE html>
<html lang="th">

<%- include('partials/head', { title: title }) %>

<style>
    :root {
        --cafe-gold: #E6C27A;
        --cafe-dark-bg: #0d0d0d;
        --glass-bg: rgba(255, 255, 255, 0.03);
        --glass-border: rgba(255, 255, 255, 0.08);
    }

    body {
        background-color: var(--cafe-dark-bg);
        padding-top: 100px;
        color: #eee;
        min-height: 100vh;
        background: linear-gradient(rgba(13,13,13,0.9), rgba(13,13,13,0.9)), 
                    url('https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?auto=format&fit=crop&q=80&w=2000');
        background-size: cover;
        background-attachment: fixed;
    }

    .form-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 20px;
    }

    .section-box {
        background: rgba(25, 25, 25, 0.4);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 24px;
        padding: 40px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .form-header {
        text-align: center;
        margin-bottom: 40px;
    }

    .form-header h2 {
        color: var(--cafe-gold);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .form-label {
        color: #888;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 10px;
        display: block;
    }

    .form-control, .form-select {
        background: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid var(--glass-border) !important;
        color: #fff !important;
        border-radius: 12px;
        padding: 15px;
        transition: all 0.3s ease;
    }

    .form-control:focus, .form-select:focus {
        border-color: var(--cafe-gold) !important;
        box-shadow: 0 0 0 4px rgba(230, 194, 122, 0.1) !important;
    }

    .preview-container {
        width: 100%;
        max-width: 300px;
        aspect-ratio: 1;
        background: rgba(0,0,0,0.15);
        border: 2px dashed var(--glass-border);
        border-radius: 24px;
        margin-top: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        position: relative;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .preview-container:hover {
        border-color: var(--cafe-gold);
        background: rgba(230, 194, 122, 0.05);
        transform: scale(1.02);
    }

    .preview-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 1;
    }

    .preview-placeholder {
        text-align: center;
        color: #666;
        transition: all 0.3s ease;
        z-index: 0;
        position: absolute;
    }

    .preview-container:hover .preview-placeholder {
        color: var(--cafe-gold);
    }

    .preview-placeholder i {
        font-size: 3rem;
        margin-bottom: 10px;
        display: block;
    }

    .btn-save {
        background: var(--cafe-gold);
        color: #000;
        border: none;
        border-radius: 12px;
        padding: 15px 40px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        transition: all 0.3s ease;
    }

    .btn-save:hover {
        background: #f0d49a;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    }

    .btn-back {
        background: transparent;
        color: #888;
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        padding: 15px 30px;
        text-transform: uppercase;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        text-decoration: none !important;
    }

    .btn-back:hover {
        background: rgba(255,255,255,0.05);
        color: #fff;
    }
</style>

<body>
    <%- include('navbar.ejs', { user: user }) %>

    <div class="form-container">
        <div class="section-box">
            <div class="form-header">
                <h2>ปรับปรุงข้อมูลสินค้า</h2>
                <div class="text-muted small">ปรับแต่งรายละเอียดสินค้าของ Dome Noir</div>
            </div>

            <form method="POST" action="/update" enctype="multipart/form-data">
                <input type="hidden" value="<%= product.id %>" name="id">
                
                <div class="row">
                    <div class="col-md-7">
                        <div class="mb-4">
                            <label class="form-label">ชื่อรายการสินค้า</label>
                            <input type="text" name="name" class="form-control" value="<%= product.name %>" required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">หมวดหมู่</label>
                            <select name="category" class="form-select" required>
                                <option value="กาแฟ" <%= product.category === 'กาแฟ' ? 'selected' : '' %>>กาแฟ</option>
                                <option value="ชา" <%= product.category === 'ชา' ? 'selected' : '' %>>ชา</option>
                                <option value="ช็อกโกแลตและนม" <%= product.category === 'ช็อกโกแลตและนม' ? 'selected' : '' %>>ช็อกโกแลตและนม</option>
                                <option value="โซดา" <%= product.category === 'โซดา' ? 'selected' : '' %>>โซดา</option>
                                <option value="เมนูปั่น" <%= product.category === 'เมนูปั่น' ? 'selected' : '' %>>เมนูปั่น</option>
                                <option value="เบเกอรี่" <%= product.category === 'เบเกอรี่' ? 'selected' : '' %>>เบเกอรี่</option>
                                <option value="อื่นๆ" <%= product.category === 'อื่นๆ' ? 'selected' : '' %>>อื่นๆ</option>
                            </select>
                        </div>

                        <div class="mb-5">
                            <label class="form-label">ราคาต่อหน่วย (บาท)</label>
                            <input type="number" name="price" class="form-control" value="<%= product.price %>" required>
                        </div>
                    </div>

                    <div class="col-md-5">
                        <label class="form-label">รูปภาพสินค้า</label>
                        <input type="file" id="imageInput" name="image" class="d-none" onchange="previewImage(event)" accept="image/*">
                        <div class="preview-container" onclick="document.getElementById('imageInput').click()">
                            <div id="placeholder" class="preview-placeholder" style="display: none;">
                                <i class="fas fa-cloud-upload-alt"></i>
                                <div class="small fw-bold">คลิกเพื่อเปลี่ยนรูปภาพ</div>
                            </div>
                            <img id="preview" class="preview-img" src="/images/products/<%= product.image %>" alt="<%= product.image %>">
                        </div>
                        <div class="text-muted small mt-2 text-center">ไฟล์ปัจจุบัน: <%= product.image %></div>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-4">
                    <a href="/manage" class="btn-back">
                        ยกเลิก
                    </a>
                    <button type="submit" class="btn-save">
                        ยืนยันการแก้ไข
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function previewImage(event) {
            const reader = new FileReader();
            const preview = document.getElementById("preview");
            const placeholder = document.getElementById("placeholder");
            
            reader.onload = function () {
                preview.src = reader.result;
                preview.style.display = "block";
                placeholder.style.display = "none";
            }
            if (event.target.files[0]) {
                reader.readAsDataURL(event.target.files[0]);
            }
        }
    </script>
</body>
</html>