<!DOCTYPE html>
<html lang="th">

<%- include('partials/head', { title: 'ศูนย์ควบคุมคลังสินค้า | Dome Noir' }) %>

<style>
    :root {
        --cafe-gold: #E6C27A;
        --cafe-dark-bg: #0d0d0d;
        --glass-bg: rgba(255, 255, 255, 0.03);
        --glass-border: rgba(255, 255, 255, 0.08);
    }

    body {
        background-color: var(--cafe-dark-bg);
        padding-top: 100px;
        color: #eee;
    }

    .manage-header {
        margin-bottom: 40px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--glass-border);
    }

    .section-box {
        background: var(--glass-bg);
        backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 24px;
        padding: 35px;
        margin-bottom: 30px;
    }

    /* Search & Filter */
    .filter-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
        margin-bottom: 30px;
    }

    .search-wrapper {
        flex: 1;
        max-width: 400px;
        position: relative;
    }

    .search-wrapper i {
        position: absolute;
        left: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: #666;
    }

    .search-wrapper .form-control {
        padding-left: 45px;
        height: 50px;
        background: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid var(--glass-border) !important;
        border-radius: 12px;
        color: #fff !important;
    }

    .search-wrapper .form-control:focus {
        border-color: var(--cafe-gold) !important;
        box-shadow: 0 0 0 4px rgba(230, 194, 122, 0.1) !important;
    }

    .btn-manage-cat {
        border: 1px solid var(--glass-border);
        color: #888;
        padding: 8px 16px;
        border-radius: 25px;
        font-size: 0.85rem;
        transition: all 0.3s ease;
        background: transparent;
    }

    .btn-manage-cat:hover, .btn-manage-cat.active {
        background: rgba(230, 194, 122, 0.1);
        color: var(--cafe-gold);
        border-color: var(--cafe-gold);
    }

    /* Premium Table */
    .premium-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 8px;
    }

    .premium-table th {
        color: #666;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        padding: 15px 25px;
        border-bottom: 1px solid var(--glass-border);
    }

    .premium-table td {
        background: rgba(255, 255, 255, 0.02);
        padding: 20px 25px;
        vertical-align: middle;
        color: #ccc;
        font-size: 0.95rem;
    }

    .premium-table tr td:first-child { border-radius: 15px 0 0 15px; }
    .premium-table tr td:last-child { border-radius: 0 15px 15px 0; }

    .premium-table tr:hover td {
        background: rgba(255, 255, 255, 0.04);
        color: #fff;
    }

    .product-img {
        width: 60px;
        height: 60px;
        object-fit: cover;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .category-badge {
        padding: 5px 12px;
        background: rgba(255, 255, 255, 0.05);
        color: #aaa;
        border-radius: 8px;
        font-size: 0.8rem;
    }

    .price-tag {
        font-weight: 600;
        color: var(--cafe-gold);
    }

    .btn-edit { 
        background: rgba(230, 194, 122, 0.05); 
        color: var(--cafe-gold); 
        border: 1px solid rgba(230, 194, 122, 0.2) !important;
        border-radius: 10px;
    }
    .btn-edit:hover { 
        background: var(--cafe-gold); 
        color: #000; 
        border-color: var(--cafe-gold) !important;
        box-shadow: 0 4px 15px rgba(230, 194, 122, 0.2);
    }

    .btn-delete { 
        background: rgba(248, 113, 113, 0.05); 
        color: #f87171; 
        border: 1px solid rgba(248, 113, 113, 0.2) !important;
        border-radius: 10px;
        text-decoration: none !important;
    }
    .btn-delete:hover { 
        background: #ef4444; 
        color: #fff; 
        border-color: #ef4444 !important;
        box-shadow: 0 4px 15px rgba(239, 68, 68, 0.2);
    }

    .btn-action {
        padding: 8px 18px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 80px;
    }

    .btn-add {
        background: var(--cafe-gold);
        color: #000;
        border-radius: 12px;
        padding: 12px 25px;
        font-weight: 700;
        letter-spacing: 0.5px;
        transition: all 0.3s ease;
        text-decoration: none !important;
    }

    .btn-add:hover {
        background: #f0d49a;
        transform: translateY(-2px);
    }
</style>

<body>
    <%- include('navbar.ejs', { user: user }) %>

    <div class="container mb-5">
        <div class="manage-header d-flex justify-content-between align-items-end">
            <div>
                <div class="welcome-text">การควบคุมคลังสินค้า</div>
                <h2 class="text-light font-weight-bold m-0 mt-1">จัดการสินค้า</h2>
            </div>
            <a href="/addForm" class="btn-add">
                เพิ่มสินค้าใหม่
            </a>
        </div>

        <div class="section-box">
            <div class="filter-section">
                <div class="search-wrapper">
                    <input type="text" id="searchInput" class="form-control" placeholder="ค้นหาด้วยชื่อ หมวดหมู่ หรือราคา..." style="padding-left: 20px;">
                </div>

                <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-manage-cat active" data-category="all" onclick="setManageCategory('all')">สินค้าทั้งหมด</button>
                    <button class="btn btn-manage-cat" data-category="กาแฟ" onclick="setManageCategory('กาแฟ')">กาแฟ</button>
                    <button class="btn btn-manage-cat" data-category="ชา" onclick="setManageCategory('ชา')">ชา</button>
                    <button class="btn btn-manage-cat" data-category="ช็อกโกแลตและนม" onclick="setManageCategory('ช็อกโกแลตและนม')">ช็อกโกแลตและนม</button>
                    <button class="btn btn-manage-cat" data-category="โซดา" onclick="setManageCategory('โซดา')">โซดา</button>
                    <button class="btn btn-manage-cat" data-category="เมนูปั่น" onclick="setManageCategory('เมนูปั่น')">เมนูปั่น</button>
                    <button class="btn btn-manage-cat" data-category="เบเกอรี่" onclick="setManageCategory('เบเกอรี่')">เบเกอรี่</button>
                </div>
            </div>

            <div class="table-responsive">
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th class="text-left" style="padding-left: 25px;">สินค้า</th>
                            <th class="text-left">หมวดหมู่</th>
                            <th class="text-center">ราคาต่อหน่วย</th>
                            <th class="text-center">การจัดการ</th>
                        </tr>
                    </thead>
                    <tbody id="productTable">
                        <% products.forEach(function(item){ %>
                        <tr>
                            <td class="text-left" style="padding-left: 25px;">
                                <div class="d-flex align-items-center">
                                    <img class="product-img mr-3" src="./images/products/<%= item.image %>" alt="<%= item.name %>">
                                    <div class="name font-weight-bold text-light"><%= item.name %></div>
                                </div>
                            </td>
                            <td class="text-left category">
                                <span class="category-badge"><%= item.category %></span>
                            </td>
                            <td class="text-center price">
                                <span class="price-tag">฿<%= item.price.toLocaleString() %></span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2" style="gap: 12px;">
                                    <form action="/edit" method="POST" class="m-0">
                                        <input type="hidden" value="<%= item._id %>" name="id">
                                        <button type="submit" class="btn-action btn-edit" title="Edit">
                                            แก้ไข
                                        </button>
                                    </form>
                                    <a class="btn-action btn-delete" href="/delete/<%= item._id %>" 
                                       onclick="return confirm('กดยืนยันเพื่อลบสินค้านี้ใช่หรือไม่?')" title="Delete">
                                        ลบ
                                    </a>
                                </div>
                            </td>
                        </tr>
                        <% }) %>                    
                    </tbody>
                </table>
            </div>
        </div>

        <script>
            let currentManageCategory = 'all';

            function setManageCategory(cat) {
                currentManageCategory = cat;
                document.querySelectorAll('.btn-manage-cat').forEach(btn => {
                    btn.classList.remove('active');
                    if(btn.dataset.category === cat) btn.classList.add('active');
                });
                filterManageTable();
            }

            function filterManageTable() {
                let filter = document.getElementById("searchInput").value.toLowerCase();
                let rows = document.querySelectorAll("#productTable tr");

                rows.forEach(row => {
                    let name = row.querySelector(".name").textContent.toLowerCase();
                    let category = row.querySelector(".category").textContent.trim().toLowerCase();
                    let price = row.querySelector(".price").textContent.toLowerCase();
                    
                    const matchesSearch = (name.includes(filter) || category.includes(filter) || price.includes(filter));
                    const matchesCategory = (currentManageCategory === 'all' || category === currentManageCategory.toLowerCase());

                    row.style.display = (matchesSearch && matchesCategory) ? "" : "none";
                });
            }

            document.getElementById("searchInput").addEventListener("keyup", filterManageTable);
        </script>
    </div>
</body>
</html>
